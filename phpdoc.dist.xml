<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor
    configVersion="3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://www.phpdoc.org"
    xsi:noNamespaceSchemaLocation="https://docs.phpdoc.org/latest/phpdoc.xsd"
>
    <title>Control Tower API Documentation</title>
    
    <paths>
        <output>docs/api</output>
        <cache>.phpdoc/cache</cache>
    </paths>
    
    <version number="1.0">
        <api>
            <source dsn=".">
                <path>app</path>
            </source>
            
            <output>.</output>
            
            <ignore hidden="true" symlinks="true">
                <path>app/Console/Kernel.php</path>
                <path>app/Exceptions</path>
                <path>app/Http/Kernel.php</path>
            </ignore>
            
            <extensions>
                <extension>php</extension>
            </extensions>
            
            <visibility>public</visibility>
            <visibility>protected</visibility>
            
            <default-package-name>ControlTower</default-package-name>
            
            <markers>
                <marker>TODO</marker>
                <marker>FIXME</marker>
            </markers>
        </api>
    </version>
    
    <template name="default"/>
</phpdocumentor>
